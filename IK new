L0 = 0.028
L1 = 0.22
L2 = 0.20

ESP_MIN = 100
ESP_MAX = 600

BASE_DEFAULT  = 355
BASE_ROTATED  = 180
WRIST = 405
HOLE  = 110
GRIP  = 520
