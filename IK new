# แถว 1: ปุ่ม PLAY  slot 1-9
# แถว 2: ปุ่ม SAVE  slot 1-9
# ปุ่ม DEL อยู่ขวาสุด

_slot_play_btns = []
_slot_save_btns = []
_btn_del = None

def _make_slot_buttons():
    global _btn_del
    w = 0.07; gap = 0.005; start_x = 0.08
    for i in range(9):
        x = start_x + i * (w + gap)
        # PLAY row
        ax_p = fig1.add_axes([x, 0.14, w, 0.035])
        b = Button(ax_p, f"▶{i+1}", color='#2a6496', hovercolor='#3a74a6')
        b.label.set_color('white'); b.label.set_fontsize(8)
        idx = i
        b.on_clicked(lambda e, n=idx: play_slot(n))
        _slot_play_btns.append(b)
        # SAVE row
        ax_s = fig1.add_axes([x, 0.10, w, 0.035])
        b2 = Button(ax_s, f"💾{i+1}", color='#3d6b35', hovercolor='#4d7b45')
        b2.label.set_color('white'); b2.label.set_fontsize(8)
        b2.on_clicked(lambda e, n=idx: save_slot(n))
        _slot_save_btns.append(b2)
    # DEL button — ลบ slot ที่พิมพ์ใน cmd
    ax_d = fig1.add_axes([0.78, 0.05, 0.10, 0.035])
    _btn_del = Button(ax_d, "🗑 DEL", color='#8b0000', hovercolor='#a00000')
    _btn_del.label.set_color('white'); _btn_del.label.set_fontsize(8)
    _btn_del.on_clicked(lambda e: _handle_del_btn())

def _handle_del_btn():
    global typed_text
    cmd = typed_text.strip()
    if cmd.isdigit() and 1 <= int(cmd) <= 9:
        delete_slot(int(cmd)-1)
        typed_text = ""
    else:
        print("[POSE] พิมพ์เลข 1-9 ใน input ก่อนแล้วกด DEL")
        draw_all("พิมพ์ 1-9 แล้วกด DEL")

_make_slot_buttons()

