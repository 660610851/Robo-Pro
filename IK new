# Shift+1~9 = save slot
SAVE_KEYS = {'!':0,'@':1,'#':2,'$':3,'%':4,'^':5,'&':6,'*':7,'(':8}

def on_key(event):
    global typed_text
    k = event.key

    # single-key shortcuts (เฉพาะตอน input ว่าง)
    if typed_text == "":
        if k == 'g': gripper_toggle(); return
        if k == 'p': pump_toggle();    return
        if k == 't': hole_toggle();    return
        if k == 'b': base_toggle();    return

        # 1-9 = play slot
        if k in '123456789':
            play_slot(int(k)-1); return

        # Shift+1~9 = save slot
        if k in SAVE_KEYS:
            save_slot(SAVE_KEYS[k]); return

        # ) = Shift+0 = delete slot ที่พิมพ์
        if k == ')':
            _handle_del_btn(); return

    if k == 'escape':
        typed_text = ""; draw_all()
    elif k == 'backspace':
        typed_text = typed_text[:-1]; draw_all()
    elif k == 'enter':
        cmd = typed_text.strip(); typed_text = ""
        print(f"\n[graph] >> {cmd}"); _handle_cmd(cmd)
    elif k and len(k) == 1:
        typed_text += k; draw_all()

fig1.canvas.mpl_connect('key_press_event', on_key)
fig2.canvas.mpl_connect('key_press_event', on_key)
fig3.canvas.mpl_connect('key_press_event', on_key)

def _handle_cmd(cmd):
    c = cmd.lower().strip()
    if c == "q":
        rclpy.shutdown(); plt.close('all'); print("Shutdown."); return
    elif c == "home":           home()
    elif c == "ready":          ready()
    elif c == "ready0":         ready(set_origin=True)
    elif c == "pos":            show_pos()
    elif c in ("g","grip"):     gripper_toggle()
    elif c == "grip open":      gripper_open()
    elif c == "grip close":     gripper_close()
    elif c in ("p","pump"):     pump_toggle()
    elif c in ("t","hole"):     hole_toggle()
    elif c in ("b","base"):     base_toggle()

    # save <n>  หรือ  save:<n>
    elif c.startswith("save"):
        try:
            n = int(c.replace("save","").replace(":","").strip())
            save_slot(n-1)
        except: print("format: save <1-9>")

    # play <n>
    elif c.startswith("play"):
        try:
            n = int(c.replace("play","").replace(":","").strip())
            play_slot(n-1)
        except: print("format: play <1-9>")

    # del <n>
    elif c.startswith("del"):
        try:
            n = int(c.replace("del","").replace(":","").strip())
            delete_slot(n-1)
        except: print("format: del <1-9>")

    elif c.lower().startswith("servo"):
        try:
            part = c.split(":",1)[1] if ":" in c else c.split(" ",1)[1]
            parts = part.replace(","," ").split()
            idx, val = int(parts[0]), int(parts[1])
            _publish_cmd(f"SERVO:{idx}:{val}")
            print(f"  SERVO:{idx} -> {val}")
        except: print("format: servo <idx> <pulse>")

    elif c.startswith("speed ") or c.startswith("spd "):
        try: set_speed(int(c.split()[1]))
        except: print("format: speed <5-80>")

    else:
        try:
            parts = cmd.replace(","," ").split()
            move_to(float(parts[0]), float(parts[1]))
        except: print(f"Invalid: '{cmd}'")

# ── Main ────────────────────────────────────────────────────────

def main():
    global _node
    rclpy.init()
    _node = IKControllerNode()
    threading.Thread(target=rclpy.spin, args=(_node,), daemon=True).start()

    load_poses()

    print("=" * 55)
    print(f"IK Controller  L0={L0} L1={L1} L2={L2}")
    print("Slots : 1-9=play  Shift+1~9=save  )=del  del <n>=ลบ")
    print("Keys  : G=Grip  P=Pump  T=Hole  B=Base")
    print("Cmds  : home/ready/ready0/pos/speed N/x z/q")
    print("=" * 55)

    home()
    plt.show(block=False)
    _flush_draw_queue()

    import select, sys
    while any(plt.fignum_exists(f.number) for f in [fig1, fig2, fig3]):
        _flush_draw_queue()
        plt.pause(0.05)
        if select.select([sys.stdin],[],[],0)[0]:
            try:
                cmd = sys.stdin.readline().strip()
                if cmd:
                    print(f">> {cmd}")
                    _handle_cmd(cmd)
                    if cmd == "q": break
            except (KeyboardInterrupt, EOFError):
                break

    if _node: _node.destroy_node()
    rclpy.shutdown()
    plt.close('all')
    print("Shutdown complete.")

if __name__ == '__main__':
    main()
