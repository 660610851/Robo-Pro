import cv2
from flask import Flask, Response
import threading
import time
import queue

app = Flask(__name__)

# --- CONFIG ---
CAMERA_INDEX = 0
WIDTH, HEIGHT = 640, 480
FPS = 15


class CameraServer:
    def __init__(self, index):
        self.index = index
        self.running = True
        self.lock = threading.Lock()
        self.latest_frame = None
        self.has_frame = False

        self.thread = threading.Thread(target=self._capture_loop, daemon=True)
        self.thread.start()

    def _capture_loop(self):
        while self.running:

            cap = cv2.VideoCapture(self.index, cv2.CAP_V4L2)

            cap.set(cv2.CAP_PROP_FRAME_WIDTH, WIDTH)
            cap.set(cv2.CAP_PROP_FRAME_HEIGHT, HEIGHT)
            cap.set(cv2.CAP_PROP_FPS, FPS)

            # ลด buffer latency
            cap.set(cv2.CAP_PROP_BUFFERSIZE, 1)

            # ใช้ MJPEG จากกล้องตรง ๆ
            cap.set(cv2.CAP_PROP_FOURCC, cv2.VideoWriter_fourcc(*'MJPG'))

            if not cap.isOpened():
                print(f"[RETRY] ไม่เจอกล้อง {self.index}... รอ 3 วิ")
                time.sleep(3)
                continue

            print(f"[CONNECTED] กล้อง {self.index} พร้อม (AprilTag Stream)")

            while self.running:

                ret, frame = cap.read()

                if not ret or frame is None:
                    print("[LOST] กล้องหลุด")
                    break

                # overwrite frame ตลอด
                with self.lock:
                    self.latest_frame = frame
                    self.has_frame = True

            cap.release()
            time.sleep(1)

    def get_latest_frame(self):
        with self.lock:
            if not self.has_frame:
                return False, None
            return True, self.latest_frame


cam_server = CameraServer(CAMERA_INDEX)

# queue เก็บเฟรมเดียว
encode_queue = queue.Queue(maxsize=1)


def encode_worker():

    interval = 1.0 / FPS

    while True:

        start = time.time()

        success, frame = cam_server.get_latest_frame()

        if not success:
            time.sleep(0.01)
            continue

        # quality 50 → balance bandwidth + clarity
        ret, buf = cv2.imencode(
            '.jpg',
            frame,
            [cv2.IMWRITE_JPEG_QUALITY, 50]
        )

        if not ret:
            continue

        # drop frame เก่าทันที
        if encode_queue.full():
            try:
                encode_queue.get_nowait()
            except queue.Empty:
                pass

        encode_queue.put(buf.tobytes())

        elapsed = time.time() - start
        sleep_time = interval - elapsed

        if sleep_time > 0:
            time.sleep(sleep_time)


threading.Thread(target=encode_worker, daemon=True).start()


def generate():

    while True:

        try:
            data = encode_queue.get(timeout=0.2)

            yield (
                b'--frame\r\n'
                b'Content-Type: image/jpeg\r\n\r\n' +
                data +
                b'\r\n'
            )

        except queue.Empty:
            continue


@app.route('/stream')
def stream_route():

    return Response(
        generate(),
        mimetype='multipart/x-mixed-replace; boundary=frame',
        headers={
            'Cache-Control': 'no-cache, no-store, must-revalidate',
            'Pragma': 'no-cache',
            'Expires': '0'
        }
    )


def main():

    import logging

    log = logging.getLogger('werkzeug')
    log.setLevel(logging.ERROR)

    print("--- AprilTag Camera Stream Port 5000 ---")

    try:
        app.run(
            host='0.0.0.0',
            port=5000,
            threaded=True,
            debug=False,
            use_reloader=False
        )

    except Exception as e:
        print(f"Flask Fatal Error: {e}")


if __name__ == '__main__':
    main()
