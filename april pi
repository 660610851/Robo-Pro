import cv2
from flask import Flask, Response
import threading
import time
import queue

app = Flask(__name__)

# --- CONFIG ---
CAMERA_INDEX = 2        # กล้องตัวที่ 2 (AprilTag)
WIDTH, HEIGHT = 640, 480
FPS = 15
JPEG_QUALITY = 40       # เพิ่มจาก 30 → 40 ได้ภาพคมขึ้นโดยไม่หนักมาก


class CameraServer:
    def __init__(self, index):
        self.index = index
        self.running = True
        self.lock = threading.Lock()
        self.latest_frame = None
        self.has_frame = False
        self.thread = threading.Thread(target=self._capture_loop, daemon=True)
        self.thread.start()

    def _capture_loop(self):
        while self.running:
            cap = cv2.VideoCapture(self.index, cv2.CAP_V4L2)
            cap.set(cv2.CAP_PROP_FRAME_WIDTH, WIDTH)
            cap.set(cv2.CAP_PROP_FRAME_HEIGHT, HEIGHT)
            cap.set(cv2.CAP_PROP_FPS, FPS)
            cap.set(cv2.CAP_PROP_BUFFERSIZE, 1)
            cap.set(cv2.CAP_PROP_FOURCC, cv2.VideoWriter_fourcc(*'MJPG'))

            if not cap.isOpened():
                print(f"[RETRY] ไม่เจอกล้อง {self.index}... รอ 3 วิ")
                time.sleep(3)
                continue

            # ✅ Warm-up flush — ล้าง stale frames ออกก่อน
            print(f"[CONNECTED] กล้อง {self.index} กำลัง warm-up...")
            for _ in range(8):
                cap.read()

            print(f"[READY] กล้อง {self.index} พร้อม (AprilTag Stream)")

            while self.running:
                ret, frame = cap.read()
                if not ret or frame is None:
                    print("[LOST] กล้องหลุด")
                    break
                with self.lock:
                    self.latest_frame = frame
                    self.has_frame = True

            cap.release()
            time.sleep(1)

    def get_latest_frame(self):
        with self.lock:
            if not self.has_frame:
                return False, None
            return True, self.latest_frame.copy()  # ✅ copy() ป้องกัน race condition


cam_server = CameraServer(CAMERA_INDEX)

encode_queue = queue.Queue(maxsize=2)  # ✅ maxsize=2 ลด drop แต่ไม่สะสม


def encode_worker():
    interval = 1.0 / FPS
    encode_params = [cv2.IMWRITE_JPEG_QUALITY, JPEG_QUALITY]

    while True:
        t0 = time.time()
        success, frame = cam_server.get_latest_frame()
        if not success:
            time.sleep(0.005)  # ✅ ลดจาก 0.01 → 0.005
            continue

        ret, buf = cv2.imencode('.jpg', frame, encode_params)
        if not ret:
            continue

        data = buf.tobytes()

        # ✅ ถ้า queue เต็ม ให้ drop frame เก่าออก
        if encode_queue.full():
            try:
                encode_queue.get_nowait()
            except queue.Empty:
                pass

        try:
            encode_queue.put_nowait(data)
        except queue.Full:
            pass

        elapsed = time.time() - t0
        sleep_time = interval - elapsed
        if sleep_time > 0:
            time.sleep(sleep_time)


threading.Thread(target=encode_worker, daemon=True).start()


def generate():
    """Generator สำหรับ multipart MJPEG stream"""
    while True:
        try:
            data = encode_queue.get(timeout=0.5)
            yield (
                b'--frame\r\n'
                b'Content-Type: image/jpeg\r\n\r\n'
                + data
                + b'\r\n'
            )
        except queue.Empty:
            # ส่ง keep-alive comment เพื่อไม่ให้ connection หลุด
            yield b'--frame\r\nContent-Type: text/plain\r\n\r\n\r\n'
            continue


@app.route('/stream')
def stream_route():
    return Response(
        generate(),
        mimetype='multipart/x-mixed-replace; boundary=frame',
        headers={
            'Cache-Control': 'no-cache, no-store, must-revalidate',
            'X-Accel-Buffering': 'no',   # ✅ สำคัญ: ปิด nginx/proxy buffer
            'Pragma': 'no-cache',
            'Expires': '0',
            'Connection': 'keep-alive',  # ✅ ไม่ให้ reconnect บ่อย
        }
    )


@app.route('/health')
def health():
    """Endpoint ตรวจสอบสถานะ"""
    status = "ok" if cam_server.has_frame else "waiting"
    return {"status": status, "camera": CAMERA_INDEX}


def main():
    import logging
    log = logging.getLogger('werkzeug')
    log.setLevel(logging.ERROR)

    print("=" * 50)
    print("  AprilTag Camera Stream — Port 5000")
    print(f"  Camera index : {CAMERA_INDEX}")
    print(f"  Resolution   : {WIDTH}x{HEIGHT} @ {FPS}fps")
    print(f"  JPEG quality : {JPEG_QUALITY}")
    print("=" * 50)

    if not cam_server.has_frame:
        print("[WAIT] รอกล้องเปิด...")

    try:
        app.run(
            host='0.0.0.0',
            port=5000,
            threaded=True,
            debug=False,
            use_reloader=False,
        )
    except Exception as e:
        print(f"[ERROR] Flask Fatal: {e}")


if __name__ == '__main__':
    main()
