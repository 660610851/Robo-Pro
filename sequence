#!/usr/bin/env python3

import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Point
from std_msgs.msg import Int32, Bool, String, Float32

import matplotlib.pyplot as plt
import time
import json
from collections import deque


# =========================
# CONFIG
# =========================

FRAME_WIDTH = 640
CENTER_THRESH = 70
ROTATE_TIMEOUT = 2.0
TAG_SEEN_TIMEOUT = 1.5
STEER_THRESH = 35

ALIGN_FAST = 180
ALIGN_SLOW = 60
TAG_LOST_GRACE = 0.5

TURN_90_TIME = 1.3   # ปรับตามความเร็วหุ่นจริง


class SequenceController(Node):

    def __init__(self):

        super().__init__('sequence_controller')

        # ================= Subscribers =================

        self.create_subscription(Bool, '/tag_detected', self.detect_callback, 10)
        self.create_subscription(Bool, '/tag_aligned', self.aligned_callback, 10)
        self.create_subscription(String, '/tag_side', self.side_callback, 10)
        self.create_subscription(Float32, '/tag_distance', self.distance_callback, 10)
        self.create_subscription(Point, '/tag_position', self.position_callback, 10)
        self.create_subscription(Int32, '/tag_planting', self.planting_callback, 10)
        self.create_subscription(Int32, '/tag_spacing', self.spacing_callback, 10)
        self.create_subscription(Int32, '/tag_cabbage', self.cabbage_callback, 10)

        # ================= Publisher =================

        self.cmd_pub = self.create_publisher(String, '/drive_cmd', 10)

        # ================= State =================

        self.tag_seen = False
        self.last_tag_seen_time = time.time()

        self.tag_aligned = False
        self.last_aligned_time = 0.0

        self.tag_side = "NONE"

        self.distance = 999
        self.last_distance = 999

        self.tag_cx = FRAME_WIDTH // 2
        self.tag_cy = 0

        self.last_offset = 0

        self.tag_planting = None
        self.tag_spacing = None
        self.tag_cabbage = None

        self.stage = 0
        self.use_tag_data = False

        self.last_cmd = ""
        self.direction_fix = 1

        self.rotate_dir = "LEFT"
        self.rotate_start_time = None

        self.turn_start_time = None

        self.dist_buffer = deque(maxlen=5)

        self.time_data = []
        self.distance_data = []
        self.start_time = time.time()

        self.timer = self.create_timer(0.1, self.loop)

        self.get_logger().info("Sequence Controller Started")

    # ======================
    # Callbacks
    # ======================

    def detect_callback(self, msg):
        self.tag_seen = msg.data
        if msg.data:
            self.last_tag_seen_time = time.time()

    def aligned_callback(self, msg):
        if msg.data:
            self.tag_aligned = True
            self.last_aligned_time = time.time()
        else:
            self.tag_aligned = False

    def side_callback(self, msg):
        self.tag_side = msg.data

    def distance_callback(self, msg):

        if msg.data <= 0:
            return

        self.dist_buffer.append(msg.data)
        self.distance = sum(self.dist_buffer) / len(self.dist_buffer)

        if self.distance <= 0.40 and not self.use_tag_data:
            self.use_tag_data = True
            self.get_logger().info("Distance ≤ 40cm → Start using tag data")

    def position_callback(self, msg: Point):

        self.tag_cx = int(msg.x)
        self.tag_cy = int(msg.y)

        offset = self.tag_cx - (FRAME_WIDTH // 2)

        if abs(offset) > 5:
            self.last_offset = offset

    def planting_callback(self, msg):
        if not self.use_tag_data:
            return
        self.tag_planting = msg.data
        self.save_config()

    def spacing_callback(self, msg):
        if not self.use_tag_data:
            return
        self.tag_spacing = msg.data
        self.save_config()

    def cabbage_callback(self, msg):
        if not self.use_tag_data:
            return
        self.tag_cabbage = msg.data
        self.save_config()

    # ======================
    # Save Config
    # ======================

    def save_config(self):

        if None in (self.tag_planting, self.tag_spacing, self.tag_cabbage):
            return

        data = {
            "tag_planting": self.tag_planting,
            "tag_spacing": self.tag_spacing,
            "tag_cabbage": self.tag_cabbage
        }

        if hasattr(self, "_last_saved_config") and self._last_saved_config == data:
            return

        self._last_saved_config = data

        with open("cabbage_config.json", "w") as f:
            json.dump(data, f, indent=4)

        self.get_logger().info("Config saved")

    # ======================
    # Publish Command
    # ======================

    def publish_cmd(self, command, force=False):

        if command == self.last_cmd and not force:
            return

        msg = String()
        msg.data = command

        self.cmd_pub.publish(msg)
        self.last_cmd = command

        self.get_logger().info(f"CMD: {command}")

    # ======================
    # Robot Control
    # ======================

    def move_forward(self):
        if self.direction_fix == 1:
            self.publish_cmd("FORWARD")
        else:
            self.publish_cmd("BACKWARD")

    def stop(self):
        self.publish_cmd("STOP")

    def search_left(self):
        self.publish_cmd("SEARCH_LEFT", force=True)

    def search_right(self):
        self.publish_cmd("SEARCH_RIGHT", force=True)

    def rotate_left(self, force=False):
        self.publish_cmd("LEFT", force=force)

    def rotate_right(self, force=False):
        self.publish_cmd("RIGHT", force=force)

    def steer_left(self):
        self.publish_cmd("STEER_LEFT", force=True)

    def steer_right(self):
        self.publish_cmd("STEER_RIGHT", force=True)

    # ======================
    # Helpers
    # ======================

    def _drive_with_steer(self, offset):

        if abs(offset) > STEER_THRESH:
            if offset > 0:
                self.steer_right()
            else:
                self.steer_left()
        else:
            self.move_forward()

    def is_tag_seen(self):

        if not self.tag_seen:
            return False

        return (time.time() - self.last_tag_seen_time) < TAG_SEEN_TIMEOUT

    # ======================
    # Main Loop
    # ======================

    def loop(self):

        now = time.time() - self.start_time

        self.time_data.append(now)
        self.distance_data.append(self.distance)

        offset = self.tag_cx - (FRAME_WIDTH // 2)
        tag_active = self.is_tag_seen()

        self.get_logger().info(
            f"Stage:{self.stage} Dist:{round(self.distance,2)} "
            f"Offset:{offset} Seen:{tag_active}"
        )

        # ======================
        # Stage 0 : Search & Align Tag
        # ======================

        if self.stage == 0:

            if not tag_active:

                time_since_seen = time.time() - self.last_tag_seen_time

                if time_since_seen < TAG_LOST_GRACE:
                    if self.last_offset > 0:
                        self.rotate_right(force=True)
                    else:
                        self.rotate_left(force=True)
                    return

                t = time.time()

                if self.rotate_start_time is None:
                    self.rotate_start_time = t

                if t - self.rotate_start_time > ROTATE_TIMEOUT:
                    self.rotate_dir = "RIGHT" if self.rotate_dir == "LEFT" else "LEFT"
                    self.rotate_start_time = t

                if self.rotate_dir == "LEFT":
                    self.search_left()
                else:
                    self.search_right()

                return

            self.rotate_start_time = None
            self.last_offset = offset

            if abs(offset) > ALIGN_FAST:

                if offset > 0:
                    self.rotate_right(force=True)
                else:
                    self.rotate_left(force=True)
                return

            elif abs(offset) > ALIGN_SLOW:

                if offset > 0:
                    self.steer_right()
                else:
                    self.steer_left()
                return

            self.stop()
            self.stage = 1
            self.get_logger().info("Stage0 DONE → Tag centered")

        # ======================
        # Stage 1 : Drive to 52cm
        # ======================

        elif self.stage == 1:

            STOP_DIST = 0.52
            SLOW_DIST = 0.65

            if self.distance <= STOP_DIST:

                self.stop()
                time.sleep(0.2)

                self.stage = 2
                self.get_logger().info("Stage1 DONE")
                return

            if self.distance < SLOW_DIST:

                if abs(offset) > STEER_THRESH:
                    if offset > 0:
                        self.steer_right()
                    else:
                        self.steer_left()
                else:
                    self.publish_cmd("SLOW_FORWARD")

            else:
                self._drive_with_steer(offset)

        # ======================
        # Stage 2 : Plant
        # ======================

        elif self.stage == 2:

            if self.tag_planting is None:
                return

            target = self.tag_planting / 100.0

            if self.distance > target:
                self._drive_with_steer(offset)
            else:
                self.stop()
                self.turn_start_time = time.time()
                self.stage = 3
                print("Stage2 DONE → Start turning left 90°")

        # ======================
        # Stage 3 : Turn Left 90°
        # ======================

        elif self.stage == 3:

            if time.time() - self.turn_start_time < TURN_90_TIME:

                self.rotate_left(force=True)

            else:

                self.stop()
                self.stage = 4
                print("Stage3 DONE → Turn complete")

        # ======================
        # Finish
        # ======================

        elif self.stage == 4:

            self.stop()

            plt.figure()
            plt.plot(self.time_data, self.distance_data)
            plt.xlabel("Time")
            plt.ylabel("Distance")
            plt.grid(True)
            plt.show()

            print("MISSION COMPLETE")

            rclpy.shutdown()

        self.last_distance = self.distance


def main():

    rclpy.init()

    node = SequenceController()

    rclpy.spin(node)

    node.destroy_node()

    rclpy.shutdown()


if __name__ == "__main__":
    main()
